    {
        "id":  "coap_sweeper_logic",
        "type":  "function",
        "z":  "floor9_tab",
        "name":  "CoAP Sweeper",
        "func":  "const floor = 9;\nfor (let i = 11; i \u003c= 20; i++) {\n    let port = 5700 + (floor - 1) * 20 + (i - 1);\n    node.send({\n        url: `coap://campus_engine:${port}/payload`,\n        method: \"GET\",\n        roomId: `b01-f09-r${i.toString().padStart(3, \u00270\u0027)}`\n    });\n}\nreturn null;",
        "outputs":  1,
        "timeout":  "",
        "noerr":  0,
