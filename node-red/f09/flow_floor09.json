    {
        "id":  "tb_rpc_router",
        "type":  "function",
        "z":  "floor9_tab",
        "name":  "RPC Protocol Router",
        "func":  "const deviceName = msg.payload.device;\nif (!deviceName.includes(\"-f09\")) { return null; } // Floor Guard\n\nconst rpcData = msg.payload.data;\nconst method = rpcData.method;\nconst params = rpcData.params;\nconst rpcId = rpcData.id; // 1. Capture the exact RPC ID from ThingsBoard\n\n// 2. Create a separate, dedicated message object for the ThingsBoard reply\nconst tbReplyMsg = {\n    payload: {\n        device: deviceName,\n        id: rpcId,\n        data: {\n            success: true,\n            state: params\n        }\n    }\n};\n\nconst cmdPayload = { hvac_mode: params };\n\nif (deviceName.endsWith(\"-COAP\")) {\n    const baseId = deviceName.replace(\"-COAP\", \"\");\n    const roomNumStr = baseId.split(\"-r\")[1];\n    const roomNum = parseInt(roomNumStr, 10);\n    const floor = 9;\n    const port = 5700 + (floor - 1) * 20 + (roomNum - 1);\n    \n    msg.url = `coap://campus_engine:${port}/actuator/hvac`;\n    msg.method = \"PUT\";\n    msg.payload = cmdPayload;\n    \n    return [null, msg, tbReplyMsg];\n} else {\n    msg.topic = \"campus/b01/cmd/\" + deviceName;\n    msg.payload = cmdPayload;\n    \n    return [msg, null, tbReplyMsg];\n}",
        "outputs":  3,
