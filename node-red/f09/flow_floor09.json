    {
        "id":  "coap_response_parser",
        "type":  "function",
        "z":  "floor9_tab",
        "name":  "Map CoAP to TB",
        "func":  "let data;\nif (typeof msg.payload === \u0027object\u0027 \u0026\u0026 !Buffer.isBuffer(msg.payload)) {\n    data = msg.payload;\n} else {\n    const raw = Buffer.isBuffer(msg.payload) ? msg.payload.toString(\u0027utf8\u0027) : msg.payload;\n    try {\n        data = JSON.parse(raw);\n    } catch(e) {\n        node.error(\u0027CoAP JSON parse failed: \u0027 + e.message + \u0027 | raw: \u0027 + raw);\n        return null;\n    }\n}\n\nconst deviceName = data.metadata.sensor_id + \"-COAP\";\nconst hvac = data.actuators.hvac_mode;\n\n// Telemetry for TB\nconst telemetry = {\n    [deviceName]: [\n        {\n            ts: Date.now(),\n            values: {\n                temperature: data.sensors.temperature,\n                humidity: data.sensors.humidity,\n                occupancy: data.sensors.occupancy,\n                light_level: data.sensors.light_level,\n                hvac_mode: hvac,\n                hvac_status: hvac,\n                lighting_dimmer: data.actuators.lighting_dimmer\n            }\n        }\n    ]\n};\n\n// Connect message to ensure RPC path is open\nconst connect = { device: deviceName };\n\nreturn [\n    { payload: telemetry },\n    { payload: connect }\n];",
        "outputs":  2,
        "noerr":  0,
        "initialize":  "",
        "finalize":  "",
        "libs":  [

                 ],
