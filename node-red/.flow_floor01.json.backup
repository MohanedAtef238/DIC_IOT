    {
        "id": "coap_sweeper_trigger",
        "type": "inject",
        "z": "floor1_tab",
        "name": "Every 5s",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "5",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 130,
        "y": 220,
        "wires": [
            [
                "coap_sweeper_logic"
            ]
        ]
    },
    {
        "id": "coap_sweeper_logic",
        "type": "function",
        "z": "floor1_tab",
        "name": "CoAP Sweeper",
        "func": "const floor = 1;\nfor (let i = 11; i <= 20; i++) {\n    let port = 5700 + (floor - 1) * 20 + (i - 1);\n    node.send({\n        url: `coap://campus_engine:${port}/payload`,\n        method: \"GET\",\n        roomId: `b01-f01-r${i.toString().padStart(3, '0')}`\n    });\n}\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 220,
        "wires": [
            [
                "coap_request_node"
            ]
        ]
    },
    {
        "id": "coap_request_node",
        "type": "coap request",
        "z": "floor1_tab",
        "method": "GET",
        "observe": false,
        "url": "",
        "content-format": "application/json",
        "raw-buffer": false,
        "name": "Room Fetcher",
        "x": 520,
        "y": 220,
        "wires": [
            [
                "coap_response_parser"
            ]
        ]
    },
    {
        "id": "coap_response_parser",
        "type": "function",
        "z": "floor1_tab",
        "name": "Map CoAP to TB",
        "func": "let data;\nif (typeof msg.payload === 'object' && !Buffer.isBuffer(msg.payload)) {\n    data = msg.payload;\n} else {\n    const raw = Buffer.isBuffer(msg.payload) ? msg.payload.toString('utf8') : msg.payload;\n    try {\n        data = JSON.parse(raw);\n    } catch(e) {\n        node.error('CoAP JSON parse failed: ' + e.message + ' | raw: ' + raw);\n        return null;\n    }\n}\n\nconst deviceName = data.metadata.sensor_id + \"-COAP\";\nconst hvac = data.actuators.hvac_mode;\n\n// Telemetry for TB\nconst telemetry = {\n    [deviceName]: [\n        {\n            ts: Date.now(),\n            values: {\n                temperature: data.sensors.temperature,\n                humidity: data.sensors.humidity,\n                occupancy: data.sensors.occupancy,\n                light_level: data.sensors.light_level,\n                hvac_mode: hvac,\n                hvac_status: hvac,\n                lighting_dimmer: data.actuators.lighting_dimmer\n            }\n        }\n    ]\n};\n\n// Connect message to ensure RPC path is open\nconst connect = { device: deviceName };\n\nreturn [\n    { payload: telemetry },\n    { payload: connect }\n];",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 730,
        "y": 220,
        "wires": [
            [
                "tb_gateway_out"
            ],
            [
                "tb_gateway_connect"
            ]
        ]
    },
    {
        "id": "uplink_formatter",
        "type": "function",
        "z": "floor1_tab",
        "name": "Map MQTT to TB",
        "func": "const deviceName = msg.payload.deviceName;\nconst hvac = msg.payload.hvac_mode;\n\nconst telemetry = {\n    [deviceName]: [\n        {\n            ts: Date.now(),\n            values: {\n                temperature: msg.payload.temperature,\n                humidity: msg.payload.humidity,\n                occupancy: msg.payload.occupancy,\n                light_level: msg.payload.light_level,\n                hvac_mode: hvac,\n                hvac_status: hvac,\n                lighting_dimmer: msg.payload.lighting_dimmer\n            }\n        }\n    ]\n};\n\nconst connect = { device: deviceName };\n\nreturn [\n    { payload: telemetry },\n    { payload: connect }\n];",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 120,
        "wires": [
            [
                "tb_gateway_out"
            ],
            [
                "tb_gateway_connect"
            ]
        ]
    },
    {
        "id": "tb_gateway_out",
        "type": "mqtt out",
        "z": "floor1_tab",
        "name": "ThingsBoard Gateway Uplink",
        "topic": "v1/gateway/telemetry",
        "qos": "1",
        "retain": "",
        "respTopic": "",
        "contentType": "",
        "userProps": "",
        "correl": "",
        "expiry": "",
        "broker": "thingsboard_broker",
        "x": 940,
        "y": 100,
        "wires": []
    },
    {
        "id": "tb_gateway_connect",
        "type": "mqtt out",
        "z": "floor1_tab",
        "name": "ThingsBoard Gateway Connect",
        "topic": "v1/gateway/connect",
        "qos": "1",
        "retain": "",
        "respTopic": "",
        "contentType": "",
        "userProps": "",
        "correl": "",
