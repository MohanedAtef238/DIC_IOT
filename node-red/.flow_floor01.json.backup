        "broker": "thingsboard_broker",
        "x": 950,
        "y": 160,
        "wires": []
    },
    {
        "id": "tb_rpc_in",
        "type": "mqtt in",
        "z": "floor1_tab",
        "name": "ThingsBoard RPC Listener",
        "topic": "v1/gateway/rpc",
        "qos": "2",
        "datatype": "auto-detect",
        "broker": "thingsboard_broker",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 160,
        "y": 320,
        "wires": [
            [
                "tb_rpc_debug",
                "tb_rpc_router"
            ]
        ]
    },
    {
        "id": "tb_rpc_router",
        "type": "function",
        "z": "floor1_tab",
        "name": "RPC Protocol Router",
        "func": "const deviceName = msg.payload.device;\nconst rpcData = msg.payload.data;\nconst method = rpcData.method;\nconst params = rpcData.params;\nconst rpcId = rpcData.id; // 1. Capture the exact RPC ID from ThingsBoard\n\n// 2. Create a separate, dedicated message object for the ThingsBoard reply\nconst tbReplyMsg = {\n    payload: {\n        device: deviceName,\n        id: rpcId,\n        data: {\n            success: true,\n            state: params\n        }\n    }\n};\n\nconst cmdPayload = { hvac_mode: params };\n\nif (deviceName.endsWith(\"-COAP\")) {\n    const baseId = deviceName.replace(\"-COAP\", \"\");\n    const roomNumStr = baseId.split(\"-r\")[1];\n    const roomNum = parseInt(roomNumStr, 10);\n    const floor = 1; // Floor 1 Flow\n    const port = 5700 + (floor - 1) * 20 + (roomNum - 1);\n    \n    msg.url = `coap://campus_engine:${port}/actuator/hvac`;\n    msg.method = \"PUT\";\n    msg.payload = cmdPayload;\n    \n    return [null, msg, tbReplyMsg];\n} else {\n    msg.topic = `campus/b01/cmd/${deviceName}`;\n    msg.payload = cmdPayload;\n    \n    return [msg, null, tbReplyMsg];\n}",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 360,
        "wires": [
            [
                "mqtt_out_command"
            ],
            [
                "coap_put_command"
            ],
            [
                "53a2a11621e8e604"
            ]
        ]
    },
