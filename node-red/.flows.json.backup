                "e6119e4f8424d0b6"
            ]
        ]
    },
    {
        "id": "e6119e4f8424d0b6",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "function 2",
        "func": "let rooms = flow.get(\"rooms\") || Array.from({ length: 20 }, () => ({\n    count: 0,\n    temp_sum: 0\n}));\n\nfor (let i = 0; i < 20; i++) {\n    let room = rooms[i];\n\n    let avg = room.count > 0 ? room.temp_sum / room.count : 0;\n\n    node.send({\n        payload: {\n            room: i + 1,\n            average: avg\n        }\n    });\n}\nflow.set(\"rooms\",undefined);\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 840,
        "wires": [
            [
                "d58541e2b69a6d99"
            ]
        ]
    },
