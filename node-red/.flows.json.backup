    {
        "id": "22e26c359a3d010d",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "subscribe mqtt",
        "func": "const floor = Number(env.get(\"FLOOR_NUMBER\") || 1);\nconst floorOffset = (floor - 1) * 20;\n\nconst floorstr = floor.toString().padStart(2, '0');\n\nfor (let room = 1; room <= 20; room+=2) {\n\n    const roomstr = (floorOffset + room).toString().padStart(3, '0');\n\n    node.send({\n        action: \"subscribe\",\n        topic: `campus/b01/floor_${floorstr}/room_${roomstr}/payload`,\n    });\n}\n\nreturn null;",
        "outputs": 1,
