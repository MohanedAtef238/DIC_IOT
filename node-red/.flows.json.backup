    {
        "id": "abb9827f2ba950db",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "observe all function",
        "func": "const floor = Number(env.get(\"FLOOR_NUMBER\") || 0);\nif (floor === 0) {\n    node.warn('FLOOR_NUMBER=0: master node, skipping CoAP observation');\n    return null;\n}\nconst floorOffset = (floor - 1) * 20;\nconst coapHost = env.get(\"COAP_HOST\") || \"campus_engine\";\n\n// Cancel any stale timers from a previous trigger (flow redeploy or catch/retry loop)\nconst prev = context.get('timers') || [];\nprev.forEach(t => clearTimeout(t));\n\nconst timers = [];\nlet delay = 0;\nfor (let room = 1; room <= 20; room+=2) {\n    const port = 5700 + floorOffset + room - 1;\n    const t = setTimeout(() => {\n        node.send({ url: `coap://${coapHost}:${port}/payload` });\n    }, delay);\n    timers.push(t);\n    delay += 3000;\n}\ncontext.set('timers', timers);\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "const timers = context.get('timers') || [];\ntimers.forEach(t => clearTimeout(t));\ncontext.set('timers', []);",
        "libs": [],
        "x": 420,
        "y": 320,
        "wires": [
            [
                "901d655a3ea08a83",
                "9fccc6fddf8f7f58"
            ]
        ]
    },
    {
        "id": "4280949f68b0f07b",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "mqtt conversion",
        "func": "const meta = msg.payload.metadata;\n\n\nconst deviceName = meta.sensor_id + \"-COAP\";\n\n\nconst values = {\n    ...msg.payload.sensors,\n    ...msg.payload.actuators\n};\n\n\nvalues.building = meta.building;\nvalues.floor = meta.floor.toString();\nvalues.room = meta.room.toString();\n\n\nconst ts = Date.now();\n\n\nmsg.topic = \"v1/gateway/telemetry\";\n\n\nmsg.payload = JSON.stringify({\n    [deviceName]: [\n        {\n            ts: ts,\n            values: values\n        }\n    ]\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 980,
        "y": 260,
        "wires": [
            [
                "3b22962487d0de80",
                "4a0d9d37895f3192"
            ]
        ]
    },
