    {
        "id": "tb_fwd_gate",
        "type": "function",
        "z": "tb_fwd_tab",
        "name": "master-only gate",
        "func": "// Only FLOOR_NUMBER=0 (master) subscribes to telemetry and forwards to ThingsBoard\nconst floor = Number(env.get('FLOOR_NUMBER') || 0);\nif (floor !== 0) return null;\n\n// Send subscribe command to the dynamic MQTT-in node\nreturn { action: 'subscribe', topic: 'campus/b01/+/+/telemetry', qos: 1 };",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 310,
        "y": 200,
        "wires": [
            [
                "tb_fwd_in"
            ]
        ]
    },
    {
        "id": "tb_fwd_in",
        "type": "mqtt in",
        "z": "tb_fwd_tab",
        "name": "all telemetry",
        "topic": "",
        "qos": "1",
        "datatype": "json",
        "broker": "75bf69f74513b636",
        "nl": false,
        "rap": false,
        "rh": 0,
        "inputs": 1,
        "x": 330,
        "y": 380,
        "wires": [
            [
                "tb_fwd_convert"
            ]
        ]
    },
    {
        "id": "tb_fwd_convert",
        "type": "function",
        "z": "tb_fwd_tab",
        "name": "gate + TB gateway format",
        "func": "// Only the master (FLOOR_NUMBER=0) forwards to ThingsBoard\nconst floor = Number(env.get('FLOOR_NUMBER') || 0);\nif (floor !== 0) return null;\n\nconst p = msg.payload;\nif (!p || !p.deviceName) return null;\n\n// Fields to exclude from telemetry values\nconst skip = new Set(['deviceName', 'building', 'floor', 'room', 'timestamp']);\nconst values = {};\nfor (const [k, v] of Object.entries(p)) {\n    if (!skip.has(k)) values[k] = v;\n}\n\n// ThingsBoard expects timestamps in milliseconds\nconst ts = p.timestamp ? p.timestamp * 1000 : Date.now();\n\nmsg.payload = JSON.stringify({\n    [p.deviceName]: [{ ts, values }]\n});\nmsg.topic = 'v1/gateway/telemetry';\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 550,
        "y": 460,
        "wires": [
            [
                "tb_fwd_out"
            ]
        ]
    },
