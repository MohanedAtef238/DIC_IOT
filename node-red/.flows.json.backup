    {
        "id": "tb_cmd_gate",
        "type": "function",
        "z": "tb_cmd_tab",
        "name": "master-only subscribe",
        "func": "const floor=Number(env.get('FLOOR_NUMBER')||0);if(floor!==0)return null;return[[{action:'subscribe',topic:'v1/gateway/attributes',qos:1},{action:'subscribe',topic:'v1/gateway/rpc',qos:1}]];",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 310,
        "y": 200,
