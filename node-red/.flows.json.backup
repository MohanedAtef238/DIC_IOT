    {
        "id": "worker_telemetry",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "floor telemetry",
        "func": "// Only process telemetry topics (not cmd)\nif (!msg.topic || !msg.topic.endsWith('/telemetry')) return null;\n\n// msg.payload is already parsed JSON (auto-detect broker setting)\n// Attach floor context for downstream calculations\nmsg.floor = Number(env.get('FLOOR_NUMBER') || 0);\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
