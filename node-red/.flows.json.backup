        ]
    },
    {
        "id": "tb_cmd_in",
        "type": "mqtt in",
        "z": "tb_cmd_tab",
        "name": "TB attr + rpc",
        "topic": "",
        "qos": "1",
        "datatype": "json",
        "broker": "tb_direct_broker",
        "nl": false,
        "rap": false,
        "rh": 0,
        "inputs": 1,
        "x": 520,
        "y": 200,
        "wires": [
            [
                "tb_cmd_parse"
            ]
        ]
    },
    {
        "id": "tb_cmd_parse",
        "type": "function",
        "z": "tb_cmd_tab",
        "name": "route to Mosquitto cmd",
        "func": "const floor=Number(env.get('FLOOR_NUMBER')||0);if(floor!==0)return null;let body;try{body=typeof msg.payload==='string'?JSON.parse(msg.payload):msg.payload;}catch(e){return null;}const deviceName=body.device;if(!deviceName)return null;let cmd={};const topic=msg.topic||'';if(topic==='v1/gateway/attributes'){const data=body.data||{};if(data.hvac_mode!==undefined)cmd.hvac_mode=data.hvac_mode;if(data.lighting_dimmer!==undefined)cmd.lighting_dimmer=parseInt(data.lighting_dimmer,10);}else if(topic==='v1/gateway/rpc'){const d=body.data||{};const method=d.method;const params=d.params;if(method==='hvac'||method==='hvac_mode'){cmd.hvac_mode=typeof params==='object'?params.hvac_mode:params;}else if(method==='light_dimmer'||method==='lighting_dimmer'){cmd.lighting_dimmer=typeof params==='object'?params.lighting_dimmer:parseInt(params,10);}}if(Object.keys(cmd).length===0)return null;msg.topic=`campus/b01/cmd/${deviceName}`;msg.payload=JSON.stringify(cmd);return msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 740,
        "y": 200,
        "wires": [
            [
                "tb_cmd_out"
            ]
        ]
    },
