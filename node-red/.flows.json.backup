    {
        "id": "1c59a27402b552f0",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "mqtt conversion 2",
        "func": "const p = msg.payload;\n\n\nconst deviceName = p.deviceName;\n\n\nconst skip = new Set([\"deviceName\", \"building\", \"floor\", \"room\", \"timestamp\"]);\n\nconst values = {};\nfor (const [k, v] of Object.entries(p)) {\n    if (!skip.has(k)) {\n        values[k] = v;\n    }\n}\n\n\nconst ts = p.timestamp ? p.timestamp * 1000 : Date.now();\n\n\nmsg.topic = \"v1/gateway/telemetry\";\n\nmsg.payload = JSON.stringify({\n    [deviceName]: [\n        {\n            ts: ts,\n            values: values\n        }\n    ]\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 550,
