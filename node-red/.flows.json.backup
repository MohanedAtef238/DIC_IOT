    {
        "id": "tb_fwd_tab",
        "type": "tab",
        "label": "TB Forward",
        "disabled": false,
        "info": "Master-only: ingests all room telemetry from Mosquitto and forwards to ThingsBoard via the MQTT gateway API (v1/gateway/telemetry). Floor workers load this flow but the gate function discards messages when FLOOR_NUMBER != 0.",
        "env": []
    },
    {
        "id": "tb_cmd_tab",
        "type": "tab",
        "label": "TB Commands",
        "disabled": false,
        "info": "Master-only: receives TB attribute updates and RPC, routes to campus/b01/cmd/<deviceName> on Mosquitto. Workers pick up cmd topics and PUT to CoAP.",
        "env": []
    },
