    {
        "id": "tb_cmd_gate",
        "type": "function",
        "z": "tb_cmd_tab",
        "name": "master-only subscribe",
        "func": "const floor = Number(env.get('FLOOR_NUMBER') || 0);\nif (floor !== 0) {\n    // Only the master node (floor 0) should subscribe to these gateway topics.\n    // Worker nodes will receive commands via the `campus/b01/cmd/...` topic.\n    return null;\n}\n\n// The master node subscribes to the ThingsBoard gateway topics for\n// shared attribute updates and RPC commands.\nnode.send({ action: 'subscribe', topic: 'v1/gateway/attributes'});\nnode.send({ action: 'subscribe', topic: 'v1/gateway/rpc'});\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 310,
        "y": 200,
        "wires": [
            [
                "tb_cmd_in"
            ]
        ]
    },
    {
        "id": "tb_cmd_in",
        "type": "mqtt in",
        "z": "tb_cmd_tab",
        "name": "TB attr + rpc",
        "topic": "",
        "qos": "1",
        "datatype": "json",
        "broker": "tb_direct_broker",
        "nl": false,
        "rap": false,
        "rh": 0,
        "inputs": 1,
        "x": 520,
        "y": 200,
        "wires": [
            [
                "tb_cmd_parse",
                "38de2aef2354574c"
            ]
        ]
    },
    {
        "id": "tb_cmd_parse",
        "type": "function",
        "z": "tb_cmd_tab",
        "name": "route to Mosquitto cmd",
        "func": "const floor=Number(env.get('FLOOR_NUMBER')||0);\nif(floor!==0)return null;\n\nlet body;\ntry{body=typeof msg.payload==='string'?JSON.parse(msg.payload):msg.payload;}catch(e){return null;}\nconst deviceName=body.device;\nif(!deviceName)return null;\n\nlet cmd={};\nconst topic=msg.topic||'';\nlet rpcMsg = null;\n\nif(topic==='v1/gateway/attributes'){\n    const data=body.data||{};\n    if(data.hvac_mode!==undefined)cmd.hvac_mode=data.hvac_mode;\n    if(data.lighting_dimmer!==undefined)cmd.lighting_dimmer=parseInt(data.lighting_dimmer,10);\n}else if(topic==='v1/gateway/rpc'){\n    const d=body.data||{};\n    const method=d.method;\n    const params=d.params;\n    if(method==='hvac'||method==='hvac_mode'){\n        cmd.hvac_mode=typeof params==='object'?params.hvac_mode:params;\n    }else if(method==='light_dimmer'||method==='lighting_dimmer'){\n        cmd.lighting_dimmer=typeof params==='object'?params.lighting_dimmer:parseInt(params,10);\n    }\n    if (d.id !== undefined) {\n        rpcMsg = {\n            topic: 'v1/gateway/rpc',\n            payload: JSON.stringify({\n                device: deviceName,\n                id: d.id,\n                data: { success: true }\n            })\n        };\n    }\n}\n\nif(Object.keys(cmd).length===0) return [null, rpcMsg];\n\nlet cmdMsg = {\n    topic: `campus/b01/cmd/${deviceName}`,\n    payload: JSON.stringify(cmd)\n};\n\nreturn [cmdMsg, rpcMsg];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 950,
        "y": 120,
        "wires": [
            [
                "tb_cmd_out"
            ],
            [
                "tb_rpc_reply_out"
            ]
        ]
    },
