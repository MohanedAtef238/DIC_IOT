        "qos": "1",
        "retain": "",
        "respTopic": "",
        "contentType": "",
        "userProps": "",
        "correl": "",
        "expiry": "",
        "broker": "tb_direct_broker",
        "x": 860,
        "y": 220,
        "wires": []
    },
    {
