    {
        "id": "640523f04dce4820",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "accumulate for average",
        "func": "let rooms = flow.get(\"rooms\") || Array.from({ length: 20 }, () => ({\n    count: 0,\n    temp_sum: 0\n}));\n\nlet curr_room = (msg.payload.metadata.room - 1)%20;\nrooms[curr_room].count++;\nrooms[curr_room].temp_sum+=msg.payload.sensors.temperature;\n\nflow.set(\"rooms\",rooms);\n\nmsg.payload = rooms[curr_room];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 970,
        "y": 360,
        "wires": [
            [
                "062fdea63fb0f04e"
            ]
        ]
    },
    {
        "id": "ee8043c0beba5ba1",
        "type": "inject",
        "z": "6db520c8e77fa5c3",
        "name": "",
        "props": [
            {
                "p": "payload"
            },
            {
                "p": "topic",
                "vt": "str"
            }
        ],
        "repeat": "60",
        "crontab": "",
        "once": true,
        "onceDelay": "60",
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 210,
        "y": 880,
        "wires": [
            [
                "e6119e4f8424d0b6"
            ]
        ]
    },
    {
        "id": "e6119e4f8424d0b6",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "function 2",
        "func": "const floor = Number(env.get(\"FLOOR_NUMBER\") || 0);\nif (floor === 0) {\n    node.warn('FLOOR_NUMBER=0: master node');\n    return null;\n}\nlet rooms = flow.get(\"rooms\") || Array.from({ length: 20 }, () => ({\n    count: 0,\n    temp_sum: 0\n}));\n\nfor (let i = 0; i < 20; i++) {\n    let room = rooms[i];\n\n    let avg = room.count > 0 ? room.temp_sum / room.count : 0;\n\n    // Build device name (adjust if needed)\n    const deviceName = `b01-f01-r${(i + 1).toString().padStart(3, '0')}`;\n\n    node.send({\n        topic: \"v1/gateway/telemetry\",\n        payload: JSON.stringify({\n            [deviceName]: [\n                {\n                    ts: Date.now(),\n                    values: {\n                        temperature: avg\n                    }\n                }\n            ]\n        })\n    });\n}\n\n// reset after sending\nflow.set(\"rooms\", undefined);\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 500,
        "y": 860,
        "wires": [
            [
                "d58541e2b69a6d99",
                "80bc2d88ac44be79"
            ]
        ]
    },
