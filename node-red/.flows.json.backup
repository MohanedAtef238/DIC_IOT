    {
        "id": "abb9827f2ba950db",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "observe all function",
        "func": "const floor = Number(env.get(\"FLOOR_NUMBER\") || 0);\nif (floor === 0) {\n    node.warn('FLOOR_NUMBER=0: master node, skipping CoAP observation');\n    return null;\n}\nconst floorOffset = (floor - 1) * 20;\nconst coapHost = env.get(\"COAP_HOST\") || \"campus_engine\";\n\n// Cancel any stale timers from a previous trigger (flow redeploy or catch/retry loop)\nconst prev = context.get('timers') || [];\nprev.forEach(t => clearTimeout(t));\n\nconst timers = [];\nlet delay = 0;\nfor (let room = 2; room <= 20; room += 2) {\n    const port = 5700 + floorOffset + room - 1;\n    const t = setTimeout(() => {\n        node.send({ url: `coap://${coapHost}:${port}/payload` });\n    }, delay);\n    timers.push(t);\n    delay += 3000;\n}\ncontext.set('timers', timers);\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "const timers = context.get('timers') || [];\ntimers.forEach(t => clearTimeout(t));\ncontext.set('timers', []);",
        "libs": [],
        "x": 420,
        "y": 320,
        "wires": [
            [
                "901d655a3ea08a83",
                "9fccc6fddf8f7f58"
            ]
        ]
    },
    {
        "id": "4280949f68b0f07b",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "mqtt conversion",
        "func": "const f = msg.payload.metadata.floor.toString().padStart(2, '0');\nconst r = msg.payload.metadata.room.toString().padStart(3, '0');\nmsg.topic = `campus/b01/f${f}/r${r}/telemetry`;\n\nmsg.payload = {\n    deviceName: msg.payload.metadata.sensor_id + \"-COAP\",\n    building: msg.payload.metadata.building,\n    floor: msg.payload.metadata.floor.toString(),\n    room: msg.payload.metadata.room.toString(),\n    ...msg.payload.sensors,\n    ...msg.payload.actuators\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 960,
        "y": 320,
        "wires": [
