    {
        "id": "coap_cmd_parse",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "build CoAP PUT",
        "func": "const parts=msg.topic.split('/');const deviceName=parts[parts.length-1];const match=deviceName.match(/r([0-9]+)-COAP/);if(!match)return null;const roomNum=parseInt(match[1],10);const port=5700+roomNum-1;const coapHost=env.get('COAP_HOST')||'campus_engine';let payload;try{payload=typeof msg.payload==='string'?JSON.parse(msg.payload):msg.payload;}catch(e){return null;}if(payload.hvac_mode!==undefined){msg.url=`coap://${coapHost}:${port}/actuator/hvac`;msg.payload=JSON.stringify({hvac_mode:payload.hvac_mode});}else if(payload.lighting_dimmer!==undefined){msg.url=`coap://${coapHost}:${port}/actuator/light_dimmer`;msg.payload=JSON.stringify({lighting_dimmer:payload.lighting_dimmer});}else{return null;}return msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1190,
        "y": 500,
        "wires": [
            [
                "coap_cmd_put"
            ]
        ]
    },
