    {
        "id": "abb9827f2ba950db",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "observe all function",
        "func": "const floor = Number(env.get(\"FLOOR_NUMBER\") || 1);\nconst floorOffset = (floor - 1) * 20;\nconst coapHost = env.get(\"COAP_HOST\") || \"campus_engine\";\n\nfor (let room = 1; room <= 20; room++) {\n    const port = 5700 + floorOffset + (room - 1);\n    node.send({ url: `coap://${coapHost}:${port}/payload` });\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 320,
        "wires": [
            [
                "901d655a3ea08a83",
                "9fccc6fddf8f7f58"
            ]
        ]
    },
    {
        "id": "4280949f68b0f07b",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "mqtt conversion",
        "func": "msg.topic = `campus/b01/floor_${msg.payload.metadata.floor}/room_${msg.payload.metadata.room}/payload`\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
