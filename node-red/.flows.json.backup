    {
        "id": "d69534778053eeda",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "accumulate for average 2",
        "func": "let rooms = flow.get(\"rooms\") || Array.from({ length: 20 }, () => ({\n    count: 0,\n    temp_sum: 0\n}));\n\nlet curr_room = (msg.payload.room - 1)%20;\nrooms[curr_room].count++;\nrooms[curr_room].temp_sum+=msg.payload.temperature;\n\nflow.set(\"rooms\",rooms);\n\nmsg.payload = rooms[curr_room];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 720,
        "wires": [
            [
                "9153fa5d176c9abe"
            ]
        ]
