    {
        "id": "ca17e0f31e5c9bd8",
        "type": "function",
        "z": "6db520c8e77fa5c3",
        "name": "subscribe to all",
        "func": "const floor = Number(env.get(\"FLOOR_NUMBER\") || 0);\nif (floor === 0) {\n    node.warn('FLOOR_NUMBER=0: master node, skipping MQTT subscriptions');\n    return null;\n}\nconst floorOffset = (floor - 1) * 20;\nconst floorstr = floor.toString().padStart(2, '0');\n\n// Subscribe to all telemetry on this floor (MQTT rooms + CoAP-converted)\nnode.send({ action: \"subscribe\", topic: `campus/b01/f${floorstr}/+/telemetry` });\n\n// Subscribe to cmd topics for CoAP rooms on this floor\nfor (let room = 2; room <= 20; room += 2) {\n    const roomstr = (floorOffset + room).toString().padStart(3, '0');\n    node.send({\n        action: \"subscribe\",\n        topic: `campus/b01/cmd/b01-f${floorstr}-r${roomstr}-COAP`,\n    });\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 500,
