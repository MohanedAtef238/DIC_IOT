#Fleet sizing
NUM_FLOORS=10
ROOMS_PER_FLOOR=20

#Thermal physics constants
# 0 to 1, how fast room temp drifts toward outside temp
ALPHA=0.05
# beta: HVAC actuator impact per tick
BETA=0.3
# Simulated outdoor temperature in °C
OUTSIDE_TEMP=20.0
# Default setpoint every room targets
DEFAULT_TARGET_TEMP=24.0

# MQTT broker
MQTT_HOST=mosquitto
MQTT_PORT=8883

# TLS — path inside the containers (mounted via docker-compose volumes)
MQTT_CA_CERT=/certs/ca.crt
MQTT_CLIENT_CERT=/certs/engine.crt
MQTT_CLIENT_KEY=/certs/engine.key

# DTLS Pre-Shared Key for CoAP rooms (generated by certs/generate_certs.sh)
COAP_DTLS_ENABLED=False
DTLS_PSK_IDENTITY=campus-iot-sensor
DTLS_PSK_KEY_B64=5mgqmTU9Qfk2Lp62EyPzjqukoyAb1N5X14sWmh98dHA=

#   Timing (seconds)  
PUBLISH_INTERVAL=5
LOG_LEVEL=WARNING

#   Fault injection  
# Probability (0–1) that any room develops a fault on a given tick
#FAULT_PROBABILITY=0.8 

HEALTH_INTERVAL = 30

# MQTT broker credentials (engine service account — re-run certs/generate_certs.sh to rotate)
MQTT_USER=engine
