#Fleet sizing
NUM_FLOORS=10
ROOMS_PER_FLOOR=20

#Thermal physics constants
# 0 to 1, how fast room temp drifts toward outside temp
ALPHA=0.05
# beta: HVAC actuator impact per tick
BETA=0.3
# Simulated outdoor temperature in °C
OUTSIDE_TEMP=20.0
# Default setpoint every room targets
DEFAULT_TARGET_TEMP=24.0

# MQTT broker
MQTT_HOST=mosquitto
MQTT_PORT=1883

#   Timing (seconds)  
PUBLISH_INTERVAL=5

#   Fault injection  
# Probability (0–1) that any room develops a fault on a given tick
FAULT_PROBABILITY=0.02 

